# Required
ANTHROPIC_API_KEY=sk-ant-...
# Use bcrypt hash (recommended for production):
#   python scripts/hash_password.py 'your-secure-password'
APP_PASSWORD_HASH=
# Or plain password (dev only — min 16 chars in production):
APP_PASSWORD=your-secure-password

# OpenAI (optional — chat summaries if no Anthropic key)
# OPENAI_API_KEY=sk-...

# X (Twitter) API — OAuth 1.0a user context
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# Web search (Google News RSS) — primary for earnings, mergers, company news
WEB_SEARCH_ENABLED=true

# Push notifications (generate with: npx web-push generate-vapid-keys)
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_CLAIMS_EMAIL=mailto:you@example.com

# Alerting (Slack/Discord webhook URL)
# ALERT_WEBHOOK_URL=

# Optional — supplemental structured data (earnings calendar, macro, quotes)
# Free key: https://finnhub.io/register
FINNHUB_KEY=

# Market movers — Finnhub quote scan for big % moves and 52-week highs
# MARKET_MOVERS_ENABLED=true
# MARKET_MOVER_PCT_THRESHOLD=4.0
# MAX_DRAFTS_PER_CYCLE=6
# DEFAULT_MARKET_UNIVERSE=AAPL,MSFT,NVDA,AMZN,GOOGL,META,TSLA,AMD

# App settings
# Generate: openssl rand -hex 32
SECRET_KEY=change-me-to-random-string
DRY_RUN=true
DATABASE_URL=sqlite:///./postpilot.db
LOG_LEVEL=INFO

# Production (Railway sets RAILWAY_ENVIRONMENT automatically)
# ENFORCE_SECURITY=true

# Railway sets PORT automatically — do NOT set PORT yourself on Railway
# For Railway with a volume mounted at /data, use:
# DATABASE_URL=sqlite:////data/postpilot.db
